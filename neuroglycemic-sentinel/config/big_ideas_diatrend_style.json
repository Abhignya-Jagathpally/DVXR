{
  "schema_version": "neural-glucose-training-v1",
  "prediction_target": "future_cgm_glucose_mg_dl",
  "forecast_horizons_minutes": [
    30,
    60,
    90,
    120
  ],
  "horizon_tolerance_minutes": 5.0,
  "target_standardization": "train_only_zscore_per_horizon",
  "seed": 42,
  "epochs": 150,
  "learning_rate": 0.001,
  "weight_decay": 0.0001,
  "expert_loss_weight": 0.25,
  "model": {
    "hidden_dim": 32,
    "embedding_dim": 16,
    "dropout": 0.1,
    "min_scale": 0.05,
    "modality_dropout_probability": 0.0,
    "horizon_film": true,
    "response_kernel": {
      "channels": {
        "carbohydrate_g": 1.0
      },
      "basis_centers_minutes": [
        0,
        15,
        30,
        45,
        60,
        90,
        120,
        180
      ],
      "rank": 4,
      "max_gain_deviation": 0.25
    }
  },
  "forecast_mode": "ambient_no_cgm",
  "input_cgm": false,
  "feature_registry": {
    "wearable": [
      "wearable_heart_rate_mean_bpm",
      "wearable_heart_rate_std_bpm",
      "wearable_heart_rate_min_bpm",
      "wearable_heart_rate_max_bpm",
      "wearable_heart_rate_slope_bpm_per_minute",
      "wearable_ibi_mean_seconds",
      "wearable_ibi_std_seconds",
      "wearable_ibi_rmssd_seconds",
      "wearable_meal_carbohydrate_g_240m",
      "wearable_minutes_since_meal"
    ]
  },
  "risk_thresholds_mg_dl": {
    "hypoglycemia": 70.0,
    "hyperglycemia": 180.0
  },
  "meal_context": {
    "lookback_minutes": 240,
    "lag_centers_minutes": [
      0,
      15,
      30,
      45,
      60,
      90,
      120,
      180
    ],
    "lag_width_minutes": 20,
    "value_columns": [
      "carbohydrate_g",
      "protein_g",
      "fat_g",
      "fiber_g",
      "bolus_insulin_units"
    ],
    "require_event_and_available_time_before_anchor": true
  },
  "gradient_clip_norm": 1.0,
  "early_stopping_patience": 20,
  "minimum_delta": 0.0001,
  "device": "cpu",
  "checkpoint_relative_path": "outputs/models/big_ideas_diatrend_style_best.pt",
  "crps_loss_weight": 0.1,
  "lr_warmup_epochs": 5,
  "lr_min_ratio": 0.05,
  "ema_decay": 0.999,
  "min_anchor_spacing_minutes": 30,
  "_note": "DiaTrend-style multi-horizon (30/60/90/120) forecasting on the real BIG-IDEAS wearable/CGM cohort. Substitute cohort for the DUA-gated DiaTrend dataset; feature schema matches BIG-IDEAS (ambient_no_cgm, wearable-only). DiaTrend config diatrend_glucose.json remains wired for real DiaTrend workbooks."
}