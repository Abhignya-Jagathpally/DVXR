# SIGNAL — Research simulator environment variables.
# Copy to `.env` (or `.env.local`) and adjust. Vite only exposes vars prefixed
# with VITE_ to client code. NEVER put an API key here — the research backend is
# expected to handle authentication server-side (gateway / same-origin route).

# Base URL of the research prediction backend. The client POSTs to
# `${VITE_RESEARCH_API_URL}/v1/research/predict`. Only used when demo mode is off.
VITE_RESEARCH_API_URL=

# Env-gated demo mode. When 'true' (the default), the research simulator runs a
# transparent in-page SYNTHETIC model and stamps a "SYNTHETIC DEMONSTRATION"
# badge, so the page works fully offline. Set to 'false' to call the real
# backend at VITE_RESEARCH_API_URL instead.
VITE_RESEARCH_DEMO_MODE=true
