# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environment
venv/
.venv/

# Downloaded real datasets (re-fetch with scripts/fetch_data.py)
data/real/

# Generated synthetic fixtures
data/sample/*.csv

# Outputs: keep curated result/report artifacts, ignore large regenerable raw event dumps
outputs/*events*.csv

# scratch: BCI pipeline run on the committed sample (smoke test)
outputs/bci/metrics_sample.json

# Vendored agent skills library — not part of the deliverable
.claude/skills/
.claude/settings.local.json

# Standalone autoresearch experiment — not part of the deliverable
third_party/

# Glass-box per-subject trace cache (regenerated by `dvxr glassbox`; the example HTML is committed)
outputs/product/glassbox/trace_*.json

# Built model artifacts (produced by scripts/build_cgm_artifact.py; not committed — fail-closed on clean checkout)
artifacts/

# Frontend / integration patch working directories (their files are applied into src/ + tests/ and
# committed there; the staging copies are not part of the repo and must not ship in the cloud upload).
dvxr-user-facing-patch/
neuroglycemic-sentinel-claude-integration/
src/dvxr/serve/asgi.py.before-*

# UI recovery patch (user download) — not applied; real fix is the index.html asset path
dvxr-ui-recovery-patch/
ROOT_CAUSE_AND_DEPLOY.md
